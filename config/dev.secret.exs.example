import Config

# Copy this file to config/dev.secret.exs and fill in your values.
# Get a Gemini API key at https://aistudio.google.com/app/apikey

config :scientia_cognita, :gemini, api_key: "your-gemini-api-key-here"

# Google OAuth credentials for the "Save to Google Photos" feature.
# Create credentials at https://console.cloud.google.com (OAuth 2.0 Client ID, Web application).
# Add http://localhost:4000/auth/google/callback as an authorised redirect URI.
config :ueberauth, Ueberauth.Strategy.Google.OAuth,
  client_id: "your-google-client-id",
  client_secret: "your-google-client-secret"
